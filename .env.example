# Server Configuration
PORT=3000
NODE_ENV=production

# CORS Configuration
ALLOWED_ORIGINS=https://bub-ai.up.railway.app,https://bub-ai.web.app,http://localhost:5173

# API Configuration
API_PREFIX=/api/v1

# MySQL Configuration (Railway MySQL)
# These variables are automatically provided by Railway MySQL service
MYSQLHOST=your-mysql-host
MYSQLPORT=3306
MYSQLUSER=root
MYSQLPASSWORD=your-mysql-password
MYSQLDATABASE=railway

# Alternative: Use MYSQL_URL if provided by Railway
# MYSQL_URL=mysql://user:password@host:port/database

# JWT Secret (if using authentication)
# JWT_SECRET=your-secret-key-here
